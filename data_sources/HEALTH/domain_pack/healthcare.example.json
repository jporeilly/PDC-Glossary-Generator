  "tag_rules": [
    {
      "pattern": "\\bssn\\b|\\bdob\\b|\\bmrn\\b|\\bphi\\b|date.?of.?birth",
      "tags": [
        "phi",
        "privacy"
      ]
    },
    {
      "pattern": "\\bdx\\b|icd|diagnos|loinc|result|\\blab\\b|abnormal",
      "tags": [
        "clinical",
        "results"
      ]
    },
    {
      "pattern": "\\bndc\\b|drug|\\brx|prescri|dose|\\bdea\\b|controlled|refill",
      "tags": [
        "medication"
      ]
    },
    {
      "pattern": "\\bcpt\\b|claim|billed|allowed|paid|remit|\\b837\\b|fee.?schedule",
      "tags": [
        "claims",
        "billing",
        "coding"
      ]
    },
    {
      "pattern": "payer|insurance|medicare|medicaid|coverage|crossover",
      "tags": [
        "payer"
      ]
    },
    {
      "pattern": "disclos|consent|authoriz|opt.?out|\\bnpp\\b|privacy",
      "tags": [
        "privacy",
        "disclosure",
        "compliance"
      ]
    },
    {
      "pattern": "appt|appointment|encounter|visit|no.?show|chief.?complaint",
      "tags": [
        "encounter"
      ]
    },
    {
      "pattern": "\\bnpi\\b|provider|specialt|license|credential",
      "tags": [
        "operational"
      ]
    },
    {
      "pattern": "statement|balance|coinsurance",
      "tags": [
        "billing",
        "statement",
        "records"
      ]
    },
    {
      "pattern": "correspond|\\bletter\\b|referral|appeal|notice|intake",
      "tags": [
        "correspondence",
        "records"
      ]
    }
  ],
