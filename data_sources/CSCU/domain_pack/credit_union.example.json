  "tag_rules": [
    {
      "pattern": "\\bcard\\b|\\bpan\\b|\\bcvv\\b|\\bmcc\\b|expir",
      "tags": [
        "pci",
        "card",
        "payments"
      ]
    },
    {
      "pattern": "\\bach\\b|routing|\\brte\\b|\\bwire\\b|swift|iban",
      "tags": [
        "payments",
        "ach"
      ]
    },
    {
      "pattern": "\\bkyc\\b|\\baml\\b|\\bsar\\b|suspicious|watchlist|\\bofac\\b|\\bbsa\\b|risk.?rating",
      "tags": [
        "compliance",
        "aml"
      ]
    },
    {
      "pattern": "\\bloan|\\bapr\\b|collateral|principal|amortiz|maturity|underwrit|\\bln_",
      "tags": [
        "lending",
        "credit"
      ]
    },
    {
      "pattern": "ledger|journal|\\bgl_|dr_amt|cr_amt|debit_amount|credit_amount",
      "tags": [
        "ledger"
      ]
    },
    {
      "pattern": "fraud|dispute|chargeback|reversal",
      "tags": [
        "fraud",
        "compliance"
      ]
    },
    {
      "pattern": "statement|\\bstmt\\b",
      "tags": [
        "statement",
        "records"
      ]
    },
    {
      "pattern": "correspond|\\bletter\\b|notice|\\bmemo\\b|inquiry",
      "tags": [
        "correspondence",
        "records"
      ]
    },
    {
      "pattern": "\\bboard\\b|minutes|polic(y|ies)|procedure|handbook",
      "tags": [
        "board",
        "records",
        "governance"
      ]
    },
    {
      "pattern": "dividend|\\bapy\\b|interest.?rate|rate.?sheet|int_rt",
      "tags": [
        "rates"
      ]
    },
    {
      "pattern": "\\bmbr|member|joint.?owner|beneficiar",
      "tags": [
        "member"
      ]
    },
    {
      "pattern": "deposit|savings|checking|share.?(draft|account)|certificate",
      "tags": [
        "deposit"
      ]
    },
    {
      "pattern": "\\btxn|transaction|merchant|\\bmerch",
      "tags": [
        "transaction"
      ]
    }
  ],
