  "tag_rules": [
    {
      "pattern": "\\bpart\\b|part_no|\\brev\\b|item.?master",
      "tags": [
        "parts"
      ]
    },
    {
      "pattern": "\\bbom\\b|parent_part|child_part|qty_per|genealog",
      "tags": [
        "bom",
        "lineage",
        "parts"
      ]
    },
    {
      "pattern": "supplier|vendor|\\basl\\b|approved.?supplier",
      "tags": [
        "supplier",
        "purchasing"
      ]
    },
    {
      "pattern": "\\bpo_|purchase|promised|unit_price",
      "tags": [
        "purchasing"
      ]
    },
    {
      "pattern": "\\bwo_|work.?order|planned|completed|scrap",
      "tags": [
        "production"
      ]
    },
    {
      "pattern": "\\blot\\b|coc|certificat|trace|quarantine|recall",
      "tags": [
        "traceability",
        "lot"
      ]
    },
    {
      "pattern": "insp|sample|defect|gauge|calibrat",
      "tags": [
        "quality",
        "inspection"
      ]
    },
    {
      "pattern": "\\bncr|nonconform|disposition|\\bmrb\\b|severity|use.?as.?is|rework",
      "tags": [
        "nonconformance",
        "quality"
      ]
    },
    {
      "pattern": "ship|customer|deliver|dest_",
      "tags": [
        "shipment",
        "customer"
      ]
    },
    {
      "pattern": "unit_cost|price|quote|margin",
      "tags": [
        "commercial",
        "cost"
      ]
    },
    {
      "pattern": "safety.?critical",
      "tags": [
        "safety-critical",
        "traceability"
      ]
    },
    {
      "pattern": "iso.?9001|as.?9100|audit|surveillance",
      "tags": [
        "compliance",
        "quality"
      ]
    },
    {
      "pattern": "correspond|\\bletter\\b|notice|\\bmemo\\b|\\bemail\\b|expedite",
      "tags": [
        "correspondence",
        "records"
      ]
    }
  ],
