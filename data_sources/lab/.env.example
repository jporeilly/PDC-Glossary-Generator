# ============================================================
#  PDC demo lab — SHARED stack credentials & settings
#  One PostgreSQL + one MinIO for ALL scenarios.
#  Copy to .env before running make.
#
#  Scenario-specific values (database name, bucket, read-only
#  users) come from each scenario's scenario.json and SQL —
#  the loader script applies them; nothing scenario-flavoured
#  belongs in this file.
# ============================================================

# ---- Shared ----
LAB_NETWORK=demo-net

# ============================================================
#  PostgreSQL (one instance; one database per scenario)
# ============================================================
PG_CONTAINER=demo-postgres
# Superuser account (used to create databases and run scenario SQL)
PG_ADMIN_USER=demo_admin
PG_ADMIN_PASSWORD=admin123!
PG_PORT=5432

# ============================================================
#  MinIO (one instance; one bucket per scenario)
# ============================================================
MINIO_CONTAINER=demo-minio
MINIO_ENDPOINT=http://demo-minio:9000

# Root admin account (used only for setup: buckets, users, uploads)
MINIO_ROOT_USER=demo_admin
MINIO_ROOT_PASSWORD=minioadmin123!

# Read-only secret shared by the per-scenario PDC users
# (awc_minio_user / cscu_minio_user are created by the loader)
PDC_MINIO_SECRET=minio_secret_123!
