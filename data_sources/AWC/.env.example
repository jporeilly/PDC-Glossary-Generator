# ============================================================
#  Arizona Water Company — Lab credentials & settings
#  Single source of truth. docker-compose.yml and the Makefile
#  both read these values, so there is no credential drift.
# ============================================================

# ---- Shared ----
LAB_NETWORK=awc-net

# ============================================================
#  PostgreSQL (operational database)
# ============================================================
PG_CONTAINER=az-water-postgres
PG_DB=awc_operations
# Superuser account (used to create the DB and run init scripts)
PG_ADMIN_USER=awc_admin
PG_ADMIN_PASSWORD=admin123!
PG_PORT=5432
PG_HOST=az-water-postgres

# Read-only account that Pentaho Data Catalog connects with.
# These MUST match postgres-init/02-create-readonly-user.sql.
PDC_DB_USER=pdc_user
PDC_DB_SECRET=catalog123!

# ============================================================
#  MinIO (object store for unstructured documents)
# ============================================================
MINIO_CONTAINER=az-water-minio
MINIO_NETWORK=awc-net
MINIO_ENDPOINT=http://az-water-minio:9000

# Root admin account (used only for setup: create bucket, load files)
MINIO_ROOT_USER=awc_admin
MINIO_ROOT_PASSWORD=minioadmin123!

# Read-only account that Pentaho Data Catalog connects with
PDC_USER=awc_minio_user
PDC_SECRET=minio_secret_123!

# Bucket and document settings
BUCKET=awc-documents
DOCS_DIR=./awc-documents
