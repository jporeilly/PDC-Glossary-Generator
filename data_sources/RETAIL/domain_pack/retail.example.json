  "tag_rules": [
    {
      "pattern": "\\bcard\\b|\\bpan\\b|\\bcvv\\b|\\bauth\\b|tender|settle",
      "tags": [
        "pci",
        "card",
        "payments"
      ]
    },
    {
      "pattern": "opt.?out|consent|do.?not.?sell|ccpa|privacy",
      "tags": [
        "privacy",
        "compliance"
      ]
    },
    {
      "pattern": "loyalty|\\bcust|customer|\\btier\\b",
      "tags": [
        "customer",
        "loyalty"
      ]
    },
    {
      "pattern": "\\bsku\\b|\\bprod|merch|category_cd|assort",
      "tags": [
        "merchandising"
      ]
    },
    {
      "pattern": "qty|on_hand|reserved|reorder|stock|cycle.?count",
      "tags": [
        "inventory"
      ]
    },
    {
      "pattern": "\\border|fulfil|\\bship|channel|\\bso[-_]",
      "tags": [
        "orders"
      ]
    },
    {
      "pattern": "return|refund|restock|\\bret_",
      "tags": [
        "returns",
        "orders"
      ]
    },
    {
      "pattern": "supplier|vendor|invoice|terms_cd|\\bpo[-_]",
      "tags": [
        "supplier",
        "invoice"
      ]
    },
    {
      "pattern": "\\blp_|shrink|fraud|theft|till|abuse",
      "tags": [
        "loss-prevention",
        "fraud",
        "compliance"
      ]
    },
    {
      "pattern": "price|promo|discount|clearance|markdown|unit_cost",
      "tags": [
        "pricing"
      ]
    },
    {
      "pattern": "receipt|closeout|register",
      "tags": [
        "receipt",
        "records"
      ]
    },
    {
      "pattern": "correspond|\\bletter\\b|notice|\\bmemo\\b|inquiry|apolog",
      "tags": [
        "correspondence",
        "records"
      ]
    }
  ],
