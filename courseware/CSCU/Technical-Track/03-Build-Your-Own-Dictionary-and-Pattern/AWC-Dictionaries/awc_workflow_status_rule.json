[
  {
    "__typename": "dictionariesRules",
    "type": "Dictionary",
    "name": "AWC Workflow Status",
    "category": "AWC_Operations",
    "minSamples": 1,
    "confidenceScore": {
      "+": [
        {
          "*": [
            {
              "var": "similarity"
            },
            0.85
          ]
        },
        {
          "*": [
            {
              "var": "metadataScore"
            },
            0.15
          ]
        }
      ]
    },
    "columnNameRegex": [
      {
        "regex": "(?i)(alert)?_?status",
        "score": 0.85
      }
    ],
    "condition": {
      "or": [
        {
          ">=": [
            {
              "var": "confidenceScore"
            },
            "0.6"
          ]
        },
        {
          ">=": [
            {
              "var": "metadataScore"
            },
            "0.7"
          ]
        }
      ]
    },
    "actions": [
      {
        "applyTags": [
          {
            "k": "Workflow Status"
          }
        ]
      }
    ]
  }
]