[
  {
    "__typename": "patternsRules",
    "type": "Pattern",
    "name": "CSCU ABA Routing Number",
    "category": "CSCU_Payments",
    "status": "enabled",
    "columnNameRegex": [
      {
        "regex": "(?i)(ach_)?(rte|routing)_?(no|num|number)?",
        "score": 1.0
      }
    ],
    "columnNameWeight": 0.3,
    "contentPatterns": [
      {
        "pattern": "nnnnnnnnn"
      }
    ],
    "contentPatternWeight": 0.4,
    "contentRegex": [
      {
        "regex": "^\\d{9}$"
      }
    ],
    "contentRegexWeight": 0.3,
    "confidenceScore": {
      "+": [
        {
          "*": [
            {
              "var": "metadataScore"
            },
            0.3
          ]
        },
        {
          "*": [
            {
              "var": "patternScore"
            },
            0.4
          ]
        },
        {
          "*": [
            {
              "var": "regexScore"
            },
            0.3
          ]
        }
      ]
    },
    "condition": {
      "and": [
        {
          ">=": [
            {
              "var": "confidenceScore"
            },
            "0.7"
          ]
        }
      ]
    },
    "actions": [
      {
        "applyTags": [
          {
            "k": "Routing Number"
          },
          {
            "k": "Payments"
          },
          {
            "k": "Sensitive"
          }
        ]
      }
    ],
    "assignBusinessTerm": [
      {
        "k": "ACH Routing Number"
      }
    ]
  }
]
