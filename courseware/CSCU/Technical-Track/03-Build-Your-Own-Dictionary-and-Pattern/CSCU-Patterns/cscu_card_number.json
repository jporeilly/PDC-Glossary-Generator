[
  {
    "__typename": "patternsRules",
    "type": "Pattern",
    "name": "CSCU Payment Card Number",
    "category": "CSCU_PCI",
    "status": "enabled",
    "columnNameRegex": [
      {
        "regex": "(?i)card_?(no|num|number)|\\bpan\\b",
        "score": 1.0
      }
    ],
    "columnNameWeight": 0.3,
    "contentPatterns": [
      {
        "pattern": "nnnn-nnnn-nnnn-nnnn"
      }
    ],
    "contentPatternWeight": 0.4,
    "contentRegex": [
      {
        "regex": "^4\\d{3}-\\d{4}-\\d{4}-\\d{4}$"
      }
    ],
    "contentRegexWeight": 0.3,
    "confidenceScore": {
      "+": [
        {
          "*": [
            {
              "var": "metadataScore"
            },
            0.3
          ]
        },
        {
          "*": [
            {
              "var": "patternScore"
            },
            0.4
          ]
        },
        {
          "*": [
            {
              "var": "regexScore"
            },
            0.3
          ]
        }
      ]
    },
    "condition": {
      "and": [
        {
          ">=": [
            {
              "var": "confidenceScore"
            },
            "0.7"
          ]
        }
      ]
    },
    "actions": [
      {
        "applyTags": [
          {
            "k": "card number"
          },
          {
            "k": "pci"
          },
          {
            "k": "sensitive"
          }
        ]
      }
    ],
    "assignBusinessTerm": [
      {
        "k": "Card Number"
      }
    ]
  }
]
