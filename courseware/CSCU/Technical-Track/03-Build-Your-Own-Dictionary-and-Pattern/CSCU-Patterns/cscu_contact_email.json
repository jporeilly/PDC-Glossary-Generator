[
  {
    "__typename": "patternsRules",
    "type": "Pattern",
    "name": "CSCU Contact Email",
    "category": "CSCU_PII",
    "status": "enabled",
    "columnNameRegex": [
      {
        "regex": "(?i)e?_?mail",
        "score": 1.0
      }
    ],
    "columnNameWeight": 0.3,
    "contentPatterns": [
      {
        "pattern": "aaaa@aaaa.aaa"
      }
    ],
    "contentPatternWeight": 0.4,
    "contentRegex": [
      {
        "regex": "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$"
      }
    ],
    "contentRegexWeight": 0.3,
    "confidenceScore": {
      "+": [
        {
          "*": [
            {
              "var": "metadataScore"
            },
            0.3
          ]
        },
        {
          "*": [
            {
              "var": "patternScore"
            },
            0.4
          ]
        },
        {
          "*": [
            {
              "var": "regexScore"
            },
            0.3
          ]
        }
      ]
    },
    "condition": {
      "and": [
        {
          ">=": [
            {
              "var": "confidenceScore"
            },
            "0.7"
          ]
        }
      ]
    },
    "actions": [
      {
        "applyTags": [
          {
            "k": "email"
          },
          {
            "k": "pii"
          }
        ]
      }
    ]
  }
]
