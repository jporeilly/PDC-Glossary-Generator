[
  {
    "__typename": "patternsRules",
    "type": "Pattern",
    "name": "CSCU GL Account Number",
    "category": "CSCU_Finance",
    "status": "enabled",
    "columnNameRegex": [
      {
        "regex": "(?i)gl_?acct_?(no)?",
        "score": 1.0
      }
    ],
    "columnNameWeight": 0.3,
    "contentPatterns": [
      {
        "pattern": "nnnn"
      }
    ],
    "contentPatternWeight": 0.4,
    "contentRegex": [
      {
        "regex": "^[1245]\\d{3}$"
      }
    ],
    "contentRegexWeight": 0.3,
    "confidenceScore": {
      "+": [
        {
          "*": [
            {
              "var": "metadataScore"
            },
            0.3
          ]
        },
        {
          "*": [
            {
              "var": "patternScore"
            },
            0.4
          ]
        },
        {
          "*": [
            {
              "var": "regexScore"
            },
            0.3
          ]
        }
      ]
    },
    "condition": {
      "and": [
        {
          ">=": [
            {
              "var": "confidenceScore"
            },
            "0.7"
          ]
        }
      ]
    },
    "actions": [
      {
        "applyTags": [
          {
            "k": "GL Account"
          },
          {
            "k": "Ledger"
          }
        ]
      }
    ]
  }
]
