{
  "_id": "5ebace17-7649-54df-bb27-2acd19d1daf1",
  "name": "AWC Account",
  "type": "DataPattern",
  "isEnabled": true,
  "description": "AWC Account format",
  "note": "",
  "categories": [
    "AWC_Account"
  ],
  "rules": [
    {
      "type": "DataPattern",
      "minSamples": "200",
      "confidenceScore": {
        "+": [
          {
            "*": [
              {
                "var": "regexScore"
              },
              "0.6"
            ]
          },
          {
            "*": [
              {
                "var": "metadataScore"
              },
              "0.4"
            ]
          }
        ]
      },
      "condition": {
        "or": [
          {
            ">=": [
              {
                "var": "confidenceScore"
              },
              "0.5"
            ]
          },
          {
            ">=": [
              {
                "var": "regexScore"
              },
              "0.75"
            ]
          }
        ]
      },
      "actions": [
        {
          "applyTags": [
            {
              "name": "Account"
            },
            {
              "name": "PII"
            }
          ]
        }
      ]
    }
  ],
  "minSamples": 200,
  "dataEventThreshold": 0.5,
  "metadataHints": {
    "aliases": [
      {
        "nameRegex": "(?i)accountno*",
        "score": 0.9
      },
      {
        "nameRegex": "(?i)account*",
        "score": 0.9
      },
      {
        "nameRegex": "(?i)acct*",
        "score": 0.9
      },
      {
        "nameRegex": "(?i)no*",
        "score": 0.9
      }
    ]
  },
  "regexMatch": {
    "regex": [
      "^[0-9]{3}-[0-9]{7}$"
    ]
  }
}