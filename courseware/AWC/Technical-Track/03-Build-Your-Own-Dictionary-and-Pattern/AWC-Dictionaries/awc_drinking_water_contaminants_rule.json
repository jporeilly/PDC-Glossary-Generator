[
  {
    "__typename": "dictionariesRules",
    "type": "Dictionary",
    "name": "AWC Drinking Water Contaminants",
    "category": "AWC_Compliance",
    "minSamples": 1,
    "confidenceScore": {
      "+": [
        {
          "*": [
            {
              "var": "similarity"
            },
            0.6
          ]
        },
        {
          "*": [
            {
              "var": "metadataScore"
            },
            0.4
          ]
        }
      ]
    },
    "columnNameRegex": [
      {
        "regex": "(?i)(turbidity|ntu)",
        "score": 0.9
      },
      {
        "regex": "(?i)(lead|copper|arsenic|nitrate|fluoride|uranium|chromium)_?(ppb|ppm)?",
        "score": 0.9
      },
      {
        "regex": "(?i)(chlorine|residual|coliform|bacteria|tds|dissolved_?solids)",
        "score": 0.8
      },
      {
        "regex": "(?i)(contaminant|analyte|parameter|mcl)",
        "score": 0.7
      }
    ],
    "condition": {
      "or": [
        {
          ">=": [
            {
              "var": "confidenceScore"
            },
            "0.6"
          ]
        },
        {
          ">=": [
            {
              "var": "metadataScore"
            },
            "0.7"
          ]
        }
      ]
    },
    "actions": [
      {
        "applyTags": [
          {
            "k": "Regulated Analyte"
          },
          {
            "k": "Compliance"
          }
        ]
      }
    ],
    "assignBusinessTerm": [
      {
        "k": "Drinking Water Contaminant"
      }
    ]
  }
]