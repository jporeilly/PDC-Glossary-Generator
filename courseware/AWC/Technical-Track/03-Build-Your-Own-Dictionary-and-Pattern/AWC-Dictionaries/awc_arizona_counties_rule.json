{
  "name": "AWC Arizona Counties",
  "type": "Dictionary",
  "isEnabled": true,
  "description": "Arizona counties served by AWC",
  "note": "",
  "categories": ["AWC_Location"],
  "rules": [
    {
      "type": "Dictionary",
      "minSamples": "200",
      "confidenceScore": {
        "+": [
          { "*": [ { "var": "similarity" }, 0.8 ] },
          { "*": [ { "var": "metadataScore" }, 0.2 ] }
        ]
      },
      "condition": {
        "or": [
          { ">=": [ { "var": "confidenceScore" }, "0.6" ] },
          { ">=": [ { "var": "metadataScore" }, "0.7" ] }
        ]
      },
      "actions": [
        {
          "applyTags": [
            { "name": "Location" },
            { "name": "Arizona County" }
          ]
        }
      ]
    }
  ],
  "metadataHints": {
    "aliases": [
      { "nameRegex": "(?i)(service_?)?county", "score": 0.9 }
    ]
  },
  "csv": "AWC Arizona Counties.csv",
  "rowCount": 15
}